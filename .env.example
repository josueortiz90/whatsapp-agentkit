# AgentKit — Variables de entorno
# Copia este archivo como .env y llena tus datos:
#   cp .env.example .env
#
# Claude Code te ayuda a llenar estos valores durante el setup.
# NUNCA subas el archivo .env a GitHub.

# ── Anthropic API ──────────────────────────────────────────
# Obtener en: https://platform.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=

# ── Proveedor de WhatsApp ──────────────────────────────────
# Opciones: whapi | meta | twilio
WHATSAPP_PROVIDER=whapi

# ── Whapi.cloud (si WHATSAPP_PROVIDER=whapi) ──────────────
# Obtener en: https://whapi.cloud (plan gratis disponible)
WHAPI_TOKEN=

# ── Meta Cloud API (si WHATSAPP_PROVIDER=meta) ────────────
# Configurar en: https://developers.facebook.com
# META_ACCESS_TOKEN=
# META_PHONE_NUMBER_ID=
# META_VERIFY_TOKEN=agentkit-verify

# ── Twilio (si WHATSAPP_PROVIDER=twilio) ──────────────────
# Configurar en: https://twilio.com
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# ── Servidor ──────────────────────────────────────────────
PORT=8000
ENVIRONMENT=development

# ── Base de datos ─────────────────────────────────────────
# Local (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./agentkit.db
# Produccion (PostgreSQL en Railway):
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# ── Dashboard (HTTP Basic Auth) ───────────────────────────
# El dashboard responde 503 si DASHBOARD_PASSWORD esta vacio.
# Una vez en linea, abre https://tu-dominio/dashboard
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=

# ── Claude (opcional) ─────────────────────────────────────
# Si quieres cambiar el modelo:
# CLAUDE_MODEL=claude-sonnet-4-5

# ── Langfuse (observabilidad de prompts y costos, opcional) ─
# Cuenta gratis en https://cloud.langfuse.com
# Si LANGFUSE_PUBLIC_KEY o LANGFUSE_SECRET_KEY estan vacios, el tracing
# se desactiva automaticamente y el agente sigue funcionando.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
